# Supabase — contact form submissions are saved here
# Dashboard → Settings → API
# Server-only — do NOT prefix with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Service role key — required for /admin dashboard to read submissions.
# Supabase → Settings → API → service_role (secret). Never ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard — 6-digit passcode gate at /admin/login
# Exactly 6 digits, e.g. 472831.
ADMIN_PASSCODE=
# Random secret for signing admin session cookies. Min 16 chars.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Resend — optional email notification on new submissions
# If unset, submissions still save to Supabase but no email is sent.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are emailed (any address)
CONTACT_TO_EMAIL=BridgeToAI@proton.me

# Sender address — MUST be on a domain you've verified in Resend.
# proton.me won't work here. Use bridgetoai.com.au once you verify it.
CONTACT_FROM_EMAIL="Bridge To AI <noreply@bridgetoai.com.au>"
